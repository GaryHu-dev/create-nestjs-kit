{
  "name": "create-nestjs-kit",
  "version": "0.1.0",
  "description": "Scaffold a production-ready NestJS project from the nestjs-starter-kit template.",
  "type": "module",
  "license": "MIT",
  "author": "Gary Hu",
  "repository": { "type": "git", "url": "git+https://github.com/GaryHu-dev/create-nestjs-kit.git" },
  "homepage": "https://github.com/GaryHu-dev/create-nestjs-kit#readme",
  "bugs": { "url": "https://github.com/GaryHu-dev/create-nestjs-kit/issues" },
  "keywords": ["nestjs", "starter", "scaffold", "cli", "create", "template", "typeorm", "boilerplate"],
  "packageManager": "pnpm@11.9.0",
  "bin": { "create-nestjs-kit": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "tar": "7.5.19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
